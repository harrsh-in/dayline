# Server
NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-a-long-random-local-secret
FRONTEND_ORIGIN=http://localhost:5173

# Microsoft OAuth / Graph
MICROSOFT_CLIENT_ID=replace-with-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/calendar/microsoft/callback

# Google OAuth / Calendar
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/calendar/google/callback
